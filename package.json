{
  "name": "spaintrain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "deploy:cf": "npm run build && npx wrangler pages deploy dist --project-name spaintrain",
    "deploy:worker": "npm run build && npx wrangler deploy",
    "docker:build": "docker build -t spaintrain:latest .",
    "docker:run": "docker run --rm -p 8080:80 spaintrain:latest"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "vite": "^6.3.0",
    "vitest": "^3.2.4"
  }
}
